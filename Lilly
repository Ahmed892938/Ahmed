<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إلى ليلى</title>
    <style>
        /* إعدادات عامة وتصميم هادي */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            color: #333;
        }

        /* شاشات الموقع المشتركة */
        .container {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            text-align: center;
            width: 90%;
            max-width: 450px;
            transition: all 0.5s ease;
            position: absolute;
            opacity: 0;
            transform: scale(0.9) translateY(20px);
            pointer-events: none;
        }

        /* الشاشة النشطة حالياً */
        .container.active {
            opacity: 1;
            transform: scale(1) translateY(0);
            pointer-events: auto;
            position: relative;
        }

        /* تأثيرات المدخلات والأزرار */
        h2 {
            margin-bottom: 25px;
            color: #5c6b73;
            font-weight: 600;
        }

        input[type="password"] {
            width: 100%;
            padding: 15px;
            border: 2px solid #e1e8ed;
            border-radius: 12px;
            outline: none;
            font-size: 16px;
            text-align: center;
            transition: 0.3s;
            margin-bottom: 20px;
            background: rgba(255,255,255,0.6);
        }

        input[type="password"]:focus {
            border-color: #b5c7d3;
            box-shadow: 0 0 10px rgba(181, 199, 211, 0.3);
        }

        button {
            background: #9bb1c1;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s ease;
            font-weight: bold;
        }

        button:hover {
            background: #869dae;
            transform: translateY(-2px);
        }

        /* شاشة الرسالة */
        .message-box {
            font-size: 20px;
            line-height: 1.8;
            color: #4a5568;
            margin-bottom: 30px;
            min-height: 100px;
        }

        .word {
            display: inline-block;
            opacity: 0;
            transform: translateY(5px);
            animation: fadeInWord 0.4s forwards;
            margin-left: 5px;
        }

        @keyframes fadeInWord {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .buttons-wrapper {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .buttons-wrapper.show {
            opacity: 1;
        }

        .btn-accept {
            background-color: #a8dadc;
            color: #1d3557;
        }
        .btn-accept:hover { background-color: #90c2c4; }

        .btn-reject {
            background-color: #f1faee;
            color: #e63946;
            border: 1px solid #e63946;
        }

        /* شاشة الحب الأخيرة */
        .heart {
            font-size: 60px;
            color: #e63946;
            animation: heartbeat 1.2s infinite;
            margin-bottom: 15px;
        }

        @keyframes heartbeat {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.15); }
        }

        .love-text {
            font-size: 26px;
            color: #e63946;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <!-- الصفحة الأولى: تسجيل الدخول -->
    <div class="container active" id="page1">
        <h2>مرحباً يا ليلى 🌸</h2>
        <input type="password" id="passwordInput" placeholder="أدخلي كلمة السر الخاصة بكِ...">
        <button onclick="checkPassword()">دخول</button>
    </div>

    <!-- الصفحة الثانية: رسالة الاعتذار -->
    <div class="container" id="page2">
        <div class="message-box" id="typingMessage"></div>
        <div class="buttons-wrapper" id="actionButtons">
            <button class="btn-accept" onclick="goToLovePage()">قبلت اعتذارك</button>
            <button class="btn-reject" onclick="rejectAlert()">مقبلتش اعتذارك</button>
        </div>
    </div>

    <!-- الصفحة الثالثة: النتيجة السعيدة -->
    <div class="container" id="page3">
        <div class="heart">❤️</div>
        <div class="love-text">أنا بحبك أوي</div>
    </div>

    <script>
        // دالة التحقق من الباسورد
        function checkPassword() {
            const pass = document.getElementById('passwordInput').value;
            // الباسورد المطلوب lilly
            if (pass === 'lilly') {
                switchPage('page1', 'page2');
                setTimeout(startTyping, 600); // بدء الكتابة بعد حركة الانتقال
            } else {
                alert('كلمة السر غير صحيحة يا ليلى! ركزي شوية 🥺');
            }
        }

        // الانتقال بين الصفحات بنعومة
        function switchPage(fromId, toId) {
            document.getElementById(fromId).classList.remove('active');
            setTimeout(() => {
                document.getElementById(toId).classList.add('active');
            }, 400);
        }

        // دالة كتابة الرسالة كلمة ورا كلمة
        function startTyping() {
            const messageText = "أنا آسف يا ليلى إني زعلتك.. أنا مش هكدب عليكي تاني مهما حصل، وأتمنى تقبلي اعتذاري المرة دي بس.. ✨";
            const words = messageText.split(" ");
            const container = document.getElementById('typingMessage');
            
            words.forEach((word, index) => {
                let span = document.createElement('span');
                span.innerText = word;
                span.className = 'word';
                // تأخير ظهور كل كلمة بناءً على ترتيبها
                span.style.animationDelay = `${index * 0.35}s`;
                container.appendChild(span);
            });

            // إظهار أزرار الاختيار بعد ما النص يخلص كتابة بالكامل
            setTimeout(() => {
                document.getElementById('actionButtons').classList.add('show');
            }, words.length * 350 + 200);
        }

        // عند قبول الاعتذار
        function goToLovePage() {
            switchPage('page2', 'page3');
        }

        // الحركة المشاكسة عند رفض الاعتذار
        function rejectAlert() {
            alert('لا يا حبيبتي مفيش الأوبشن ده.. هتقبلي اعتذاري بالعافية! 😤❤️');
        }
    </script>
</body>
</html>
